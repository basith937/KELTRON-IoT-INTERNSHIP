#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT);

const int buttonPin1 = 2;
const int buttonPin2 = 3;
int currentState = 0;

void setup() {
  // put your setup code here, to run once:
  display.begin(SSD1306_SWITCHCAPVCC,0x3C);

  display.clearDisplay();
  display.display();

  pinMode(buttonPin1, INPUT_PULLUP);
  pinMode(buttonPin2, INPUT_PULLUP);

  attachInterrupt(digitalPinToInterrupt(buttonPin1), pic1, FALLING);
  attachInterrupt(digitalPinToInterrupt(buttonPin2), pic2, FALLING);

  

}

void loop() {
  // put your main code here, to run repeatedly:

  switch (currentState) {
    case 0:
    drawScreen_1();
    break;
    case 1:
    drawScreen_2();
    break;
    case 2:
    drawScreen_3();   
    break;
}
}

void pic1() {
  if (currentState > 2) {
    currentState = 0;
  }
  currentState++;
  delay(1000);
  }

void pic2()   {
  if (currentState < 0)
  {
    currentState = 2;
  }
  else{
    currentState--;
  }
  delay(1000);
}


